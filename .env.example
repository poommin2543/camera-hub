DATABASE_URL="postgresql://camera_hub:change-me@postgres:5432/camera_hub?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-bytes"
AUTH_TRUST_HOST=true
CAMERA_ENCRYPTION_KEY_FILE="/run/secrets/camera_encryption_key"
MEDIA_SIGNING_SECRET_FILE="/run/secrets/media_signing_secret"
INTERNAL_SERVICE_SECRET_FILE="/run/secrets/internal_service_secret"
CAMERA_ALLOWED_CIDRS="192.168.0.0/16,10.0.0.0/8"
CAMERA_ALLOWED_PORTS="554,8554"
MEDIA_GRANT_TTL_SECONDS="45"
MEDIAMTX_API_URL="http://mediamtx:9997"
NEXT_PUBLIC_WEBRTC_TIMEOUT_MS="7000"
NEXT_PUBLIC_EXTERNAL_STREAM_MODE="hls"
